{
  "name": "jslibs",
  "version": "1.0.0",
  "description": "A collection of libraries a maintain for my personal web stack.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "author": {
    "name": "spuxx",
    "email": "hi@spuxx.dev",
    "url": "https://spuxx.dev"
  },
  "homepage": "https://github.com/spuxx-dev/jslibs/blob/main/README.md",
  "packageManager": "pnpm@9.6.0",
  "scripts": {
    "dev": "concurrently \"pnpm dev:js-utils\" \"pnpm dev:browser-utils\" \"pnpm dev:nest-utils\" \"pnpm dev:nest-testing\" \"pnpm dev:app:react\" \"pnpm dev:app:nest\"",
    "dev:js-utils": "cd packages/js-utils && pnpm dev",
    "dev:browser-utils": "cd packages/browser-utils && pnpm dev",
    "dev:nest-utils": "cd packages/nest-utils && pnpm dev",
    "dev:nest-testing": "cd packages/nest-testing && pnpm dev",
    "dev:solid": "cd packages/solid && pnpm dev",
    "app:solid": "cd apps/solid && pnpm dev",
    "app:react": "cd apps/react && pnpm dev",
    "app:nest": "cd apps/nest && pnpm dev",
    "app:starlight": "cd apps/starlight && pnpm dev",
    "publish:test": "pnpm -r publish --dry-run --no-git-checks",
    "test": "pnpm -r test",
    "test:vitest": "pnpm -r test:vitest && pnpm coverage:vitest",
    "coverage:vitest": "node scripts/report-coverage-vitest.js",
    "check": "pnpm types && pnpm run lint && pnpm run prettier-check",
    "types": "pnpm -r types",
    "lint": "eslint . --ext ts,tsx",
    "prettier-check": "prettier --check .",
    "format": "prettier --write .",
    "docs:generate": "cd typedoc && node generate.js && cd .. && prettier --write ./typedoc/output",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "@eslint/markdown": "7.5.1",
    "@nestjs/cli": "11.0.12",
    "concurrently": "9.2.1",
    "eslint": "10.1.0",
    "globals": "17.4.0",
    "nyc": "18.0.0",
    "prettier": "3.8.1",
    "release-please": "17.2.0",
    "typescript-eslint": "8.57.1",
    "vitest": "4.1.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "playwright"
      ],
      "allowedVersions": {
        "@modyfi/vite-plugin-yaml>vite": "*"
      }
    }
  }
}
